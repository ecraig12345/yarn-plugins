{
  "name": "yarn-plugins",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "yarn tsc -b && node scripts/build.js --all",
    "clean": "node scripts/clean.js",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "workspaces": [
    "plugins/*"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/semver": "^7.0.0",
    "@yarnpkg/builder": "^4.2.2",
    "nano-spawn": "^2.0.0",
    "prettier": "^3.6.2",
    "semver": "^7.7.2",
    "syncpack": "^14.0.1",
    "typescript": "^5.5.2",
    "vitest": "^4.0.18",
    "workspace-tools": "^0.41.0"
  },
  "resolutions": {
    "glob@npm:^10.2.2": "^13.0.0",
    "minimatch@npm:^9.0.5": "^10.2.2",
    "tar@npm:^6.0.5": "^7.5.9"
  },
  "rationale": {
    "resolutions": {
      "glob@npm:^10.2.2": "Fix security issue (used API is compatible)",
      "minimatch@npm:^9.0.5": "Remove insecure dep (not actually used)",
      "tar@npm:^6.0.5": "Fix security issue (API is compatible)"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.14.1"
}
