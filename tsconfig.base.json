{
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2021",
    "lib": ["ES2021"],
    "esModuleInterop": true,
    "strict": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}
